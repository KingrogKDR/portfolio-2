---
import Section from "../Section.astro";
import { education } from "@cv";
---
<Section className={Astro.props.className} title="Education">
<ul class="space-y-4 py-3 print:space-y-0">
{
  education.map(({ institution, image, startDate, endDate, area, url }) => {
    const startYear = new Date(startDate).getFullYear();
    const endYear = endDate != null ? new Date(endDate).getFullYear() : "Actual";
    const years = `${startYear} - ${endYear}`;
    return (
      <div class="relative flex items-start justify-between gap-2">
        <div class="flex items-center gap-3">
          <img
            class="print:hidden h-8 w-8 rounded-md object-contain shadow-sm"
            src={image}
            alt={institution}
            width={32}
            height={32}
          />
          <div>
            <h3 class="items-baseline gap-x-2 gap-y-0.5 font-medium">
                {institution}
              </a>
            </h3>
            <div class="text-sm text-skin-muted">{area}</div>
          </div>
        </div>
        <time class="shrink-0 text-xs text-skin-muted">{years}</time></div>
    )
  })
}
</ul>
</Section>